# Adapterly Gateway Configuration
# Copy to .env and fill in values

# Gateway identity (set by 'python -m gateway.cli register')
GATEWAY_GATEWAY_ID=
GATEWAY_GATEWAY_SECRET=

# Control plane URL
GATEWAY_CONTROL_PLANE_URL=https://adapterly.ai

# Local security
GATEWAY_SECRET_KEY=change-me-to-a-random-string
GATEWAY_ADMIN_PASSWORD=set-a-strong-password

# Database (default: local SQLite)
GATEWAY_DB_PATH=gateway.db

# Sync intervals (seconds)
GATEWAY_SPEC_SYNC_INTERVAL=300
GATEWAY_KEY_SYNC_INTERVAL=60
GATEWAY_AUDIT_PUSH_INTERVAL=30
GATEWAY_HEALTH_PUSH_INTERVAL=60

# Server
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_DEBUG=false
